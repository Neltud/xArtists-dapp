# xArtists DApp Environment Variables
# Copy this file to .env and fill in your values

# Database (Neon or PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# MultiversX Configuration
MVX_NETWORK=devnet  # or mainnet
MVX_API_URL=https://devnet-api.multiversx.com

# MultiversX Wallet / dApp
MVX_CHAIN_ID=D  # Devnet: D, Mainnet: 1

# AI / OpenAI for artwork analysis (backend)
OPENAI_API_KEY=sk-...

# Session / Auth
SESSION_SECRET=your-super-secret-key-here

# Server
PORT=3000
NODE_ENV=development

# Optional: Faucet, Staking, TRO token addresses (update with actual)
TRO_TOKEN_ADDRESS=...
FAUCET_CONTRACT=...

# Escrow / Physical claim settings
ESCROW_ENABLED=true
